# ── REQUIRED ─────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ── OPTIONAL: Google Drive integration ───────────────────────
# Paste the entire contents of your service account JSON as a single-line string
GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"..."}

# The ID of the Drive folder where theses should be saved
# (Get this from the folder URL: drive.google.com/drive/folders/FOLDER_ID_HERE)
GOOGLE_DRIVE_FOLDER_ID=your_folder_id_here

# ── CORS: Lock down to your frontend domain in production ─────
ALLOWED_ORIGIN=https://your-frontend-domain.com

# Railway sets PORT automatically — don't change this
PORT=3001
